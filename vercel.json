{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "src/tvlc/static",
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/proxy", "destination": "/api/proxy.ts" }
  ]
}
